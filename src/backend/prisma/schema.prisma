
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id             String @id @default(cuid())
  email          String @unique
  username       String @unique
  hashedPassword String?

  avatar String?

  twoFactorEnabled Boolean @default(false)
  twoFactorSecret String?
  twoFactorTempSecret String?

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  friends  Friendship[] @relation("UserFriends")
  friendOf Friendship[] @relation("FriendOf")
  OAuthAccount OAuthAccount[]

  playedAs  Player[] // to find his stats
}

model OAuthAccount {
  id         Int    @id @default(autoincrement())
  provider   String
  providerId String

  user   User @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId String

  @@unique([provider, providerId])
}

model BlacklistedToken {
  id        Int      @id @default(autoincrement())
  token     String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@index([token])
}

model Friendship {
  id        String   @id @default(cuid())
  userId    String
  friendId  String
  createdAt DateTime @default(now())

  user   User @relation("UserFriends", fields: [userId], references: [id], onDelete: Cascade)
  friend User @relation("FriendOf", fields: [friendId], references: [id], onDelete: Cascade)

  @@unique([userId, friendId]) // pas deux fois la même paire
}

model Player {
  id        String @id @default(cuid())
  gameId    String
  userId    String?
  name      String
  status    String // ('llm' | 'user')
  score     Int @default(0)
  won		Boolean @default(false)

  logsFrom  Log[] @relation("LogsFrom")
  logsTo    Log[] @relation("LogsTo")

  game  Game  @relation(fields: [gameId], references: [id], onDelete: Cascade)
  user  User?  @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([gameId])
} 

model Log {
  id            String @id @default(cuid())
  gameId        String
  event         String
  content       String?
  playerFromId  String?
  playerToId    String?
  timestamp     DateTime @default(now())

  game        Game    @relation(fields: [gameId], references: [id], onDelete: Cascade)
  playerFrom  Player?  @relation("LogsFrom", fields: [playerFromId], references: [id], onDelete: SetNull)
  playerTo    Player?  @relation("LogsTo", fields: [playerToId], references: [id], onDelete: SetNull)

  @@index([gameId, timestamp])
}

model Game {
	id			String @id @default(cuid())
	roomId		String
	startTime	DateTime?
  winner		String?
	players		Player[]
	logs    	Log[]

	room		Room    @relation(fields: [roomId], references: [id], onDelete: Cascade)
  	@@index([roomId])
}

model Room {
  id        String @id @default(cuid())
  games		Game[]
}