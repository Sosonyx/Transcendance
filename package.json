{
  "name": "transcendance",
  "private": true,
  "type": "module",
  "workspaces": [
    "src/backend",
    "src/game"
  ],
  "scripts": {
    "postinstall": "npm run prisma:generate --workspace src/backend",
    "predev": "npm run prisma:generate --workspace src/backend",
    "dev": "tsx watch src/server.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node build/server.js",
    "prisma:generate": "npm run prisma:generate --workspace src/backend",
    "build:backend": "npm run build --workspace src/backend",
    "build:game": "npm run build --workspace src/game"
  },
  "dependencies": {
    "@fastify/static": "^9.1.3",
    "fastify": "^5.8.5",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "socket.io": "^4.8.3"
  },
  "devDependencies": {
    "@types/node": "^25.7.0",
    "@types/react": "^19.2.15",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.2",
    "tsx": "^4.21.0",
    "typescript": "^6.0.3",
    "vite": "^8.0.14"
  }
}
